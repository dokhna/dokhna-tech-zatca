{
  "name": "@dokhna-tech/zatca-storage-postgres",
  "version": "2.0.3",
  "description": "PostgreSQL storage adapter for @dokhna-tech/zatca (raw pg client).",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dokhna/dokhna-tech-zatca.git",
    "directory": "packages/storage-postgres"
  },
  "homepage": "https://github.com/dokhna/dokhna-tech-zatca#readme",
  "bugs": {
    "url": "https://github.com/dokhna/dokhna-tech-zatca/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "migrations"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "debug": "^4.3.7"
  },
  "peerDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "pg": ">=8.0.0"
  },
  "devDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "@types/debug": "^4.1.12",
    "@types/pg": "^8.11.10",
    "pg": "^8.20.0",
    "pg-mem": "^3.0.14"
  }
}
