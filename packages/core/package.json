{
  "name": "@dokhna-tech/zatca",
  "version": "2.0.1",
  "description": "Saudi Arabia ZATCA Phase 2 e-invoicing core library — XML build, signing, hashing, QR, and ZATCA API client.",
  "license": "BUSL-1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./test-helpers": {
      "types": "./dist/test-helpers.d.ts",
      "import": "./dist/test-helpers.js",
      "require": "./dist/test-helpers.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "cp ../../LICENSE ./LICENSE && cp ../../README.md ./README.md"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["zatca", "saudi-arabia", "e-invoicing", "phase-2", "ubl", "fatoora"],
  "dependencies": {
    "@fidm/x509": "^1.2.1",
    "@xmldom/xmldom": "^0.8.10",
    "debug": "^4.3.7",
    "fast-xml-parser": "^5.7.0",
    "xmldsigjs": "^2.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "msw": "^2.6.0"
  },
  "peerDependencies": {
    "vitest": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  }
}
