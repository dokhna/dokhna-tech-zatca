{
  "name": "@dokhna-tech/zatca-server",
  "version": "3.0.0",
  "description": "Standalone multi-tenant ZATCA Phase 2 server. Tenant registry, encrypted credential vault, onboarding orchestration, and ZATCA operations exposed over HTTP.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dokhna/dokhna-tech-zatca.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/dokhna/dokhna-tech-zatca#readme",
  "bugs": {
    "url": "https://github.com/dokhna/dokhna-tech-zatca/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "zatca-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "zatca",
    "saudi-arabia",
    "e-invoicing",
    "phase-2",
    "multi-tenant",
    "server",
    "docker"
  ],
  "dependencies": {
    "debug": "^4.3.7",
    "fastify": "^5.0.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "@dokhna-tech/zatca-storage-memory": "workspace:*",
    "@dokhna-tech/zatca-storage-mongo": "workspace:*",
    "@dokhna-tech/zatca-storage-postgres": "workspace:*",
    "mongoose": ">=9.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@dokhna-tech/zatca-storage-memory": {
      "optional": true
    },
    "@dokhna-tech/zatca-storage-mongo": {
      "optional": true
    },
    "@dokhna-tech/zatca-storage-postgres": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "@dokhna-tech/zatca-storage-memory": "workspace:*",
    "@dokhna-tech/zatca-storage-mongo": "workspace:*",
    "@dokhna-tech/zatca-storage-postgres": "workspace:*",
    "@types/debug": "^4.1.12",
    "@types/node": "^20.19.0",
    "@types/pg": "^8.11.10",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2",
    "pg": "^8.20.0",
    "pg-mem": "^3.0.14"
  }
}
