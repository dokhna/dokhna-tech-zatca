{
  "name": "@dokhna-tach/zatca-storage-memory",
  "version": "1.0.0",
  "description": "In-memory storage adapter for @dokhna-tach/zatca (testing/dev).",
  "license": "BUSL-1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "debug": "^4.3.7"
  },
  "peerDependencies": {
    "@dokhna-tach/zatca": "workspace:*"
  },
  "devDependencies": {
    "@dokhna-tach/zatca": "workspace:*",
    "@types/debug": "^4.1.12"
  }
}
