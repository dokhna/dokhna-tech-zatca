{
  "name": "@dokhna-tach/zatca-storage-mongo",
  "version": "0.0.0",
  "description": "MongoDB (Mongoose) storage adapter for @dokhna-tach/zatca.",
  "license": "BUSL-1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@dokhna-tach/zatca": "workspace:*",
    "mongoose": ">=8.0.0"
  }
}
