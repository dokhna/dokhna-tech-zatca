{
  "name": "@dokhna-tech/zatca-storage-mongo",
  "version": "2.0.1",
  "description": "MongoDB (Mongoose) storage adapter for @dokhna-tech/zatca.",
  "license": "BUSL-1.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "debug": "^4.3.7"
  },
  "peerDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "mongoose": ">=8.0.0"
  },
  "devDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "@types/debug": "^4.1.12",
    "mongodb-memory-server": "^10.1.2",
    "mongoose": "^9.6.2"
  }
}
