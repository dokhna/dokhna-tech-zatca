{
  "name": "@dokhna-tech/zatca-storage-mongo",
  "version": "3.0.0",
  "description": "MongoDB (Mongoose) storage adapter for @dokhna-tech/zatca.",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dokhna/dokhna-tech-zatca.git",
    "directory": "packages/storage-mongo"
  },
  "homepage": "https://github.com/dokhna/dokhna-tech-zatca#readme",
  "bugs": {
    "url": "https://github.com/dokhna/dokhna-tech-zatca/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "debug": "^4.3.7"
  },
  "peerDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "mongoose": ">=9.0.0"
  },
  "devDependencies": {
    "@dokhna-tech/zatca": "workspace:*",
    "@types/debug": "^4.1.12",
    "mongodb-memory-server": "^11.1.0",
    "mongoose": "^9.6.2"
  }
}
