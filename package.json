{
  "name": "dokhna-tach-zatca-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for @dokhna-tach/zatca — Saudi Arabia ZATCA Phase 2 e-invoicing helper.",
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --parallel build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r --parallel test",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish",
    "clean": "pnpm -r exec rm -rf dist .turbo tsconfig.tsbuildinfo && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
