{
  "name": "dokhna-tech-zatca-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for @dokhna-tech/zatca — Saudi Arabia ZATCA Phase 2 e-invoicing helper.",
  "license": "BUSL-1.1",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r --parallel test",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "docs:api": "typedoc",
    "changeset": "changeset",
    "change": "changeset add",
    "version-packages": "changeset version && biome check --write .",
    "release": "pnpm -r build && changeset publish",
    "clean": "pnpm -r exec rm -rf dist .turbo tsconfig.tsbuildinfo && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.6.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
