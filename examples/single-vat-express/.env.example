# Copy to .env and fill in real values.
# All keys are required to enable the /invoices route; /onboard works
# without them.

# Tenant identity (must already be onboarded; see /onboard).
VAT_NUMBER=301234567890003
EGS_UUID=00000000-0000-4000-8000-000000000001
VAT_NAME=Acme Trading Co.
CRN=1010010101

# Optional metadata
EGS_CUSTOM_ID=demo-pos-01
EGS_MODEL=Express POS Demo
BRANCH_NAME=Main
BRANCH_INDUSTRY=Retail
CITY_NAME=Riyadh
CITY_SUBDIVISION=Olaya
STREET=King Fahd Rd
PLOT=1234
BUILDING=5678
POSTAL_ZONE=12345

# Production signing material (from onboard()).
# In real deployments these come from a KMS or secrets manager.
ZATCA_PRODUCTION_CERTIFICATE=
ZATCA_PRIVATE_KEY=

# Server
PORT=3000
