# Standalone-server environment template.
# Copy to `.env` then fill in the secret-bearing fields below.

# ----------------------------------------------------------------------
# REQUIRED — security-sensitive
# ----------------------------------------------------------------------

# Comma-separated list of `label:key` entries. Each `key` is at least
# 32 chars; the matched label is recorded in every audit row. Rotate
# by appending a new entry and retiring the old one on the next deploy.
#
# Generate a random key:
#   openssl rand -base64 48 | tr -d '=' | head -c 48
ZATCA_SERVER_ADMIN_KEYS=ops:CHANGE_ME_TO_32_OR_MORE_RANDOM_CHARS_xxxxxxxxxxxxxx

# AES-GCM master key ring. Each entry is `kid:<base64-32-bytes>`.
# Encryption uses `ZATCA_SERVER_ACTIVE_KID`; decryption picks the kid
# stored on each ciphertext envelope so a future master-key rotation
# is zero-downtime.
#
# Generate a 32-byte key:
#   openssl rand -base64 32
ZATCA_SERVER_MASTER_KEYS=v1:CHANGE_ME_BASE64_ENCODED_32_BYTE_KEY_xxxxxxxxxxxxxx=
ZATCA_SERVER_ACTIVE_KID=v1

# ----------------------------------------------------------------------
# OPTIONAL — defaults shown
# ----------------------------------------------------------------------

# `live` for production-bearing API keys; `test` for staging tokens.
ZATCA_SERVER_TENANT_BEARER_ENV=live

# Pino log level: fatal|error|warn|info|debug|trace.
ZATCA_SERVER_LOG_LEVEL=info

# Server-side timezone; KSA local by default.
ZATCA_SERVER_TZ=Asia/Riyadh

# Bound external port. The container always listens on 3000 internally.
ZATCA_SERVER_PORT=3000
